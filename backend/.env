# Server Configuration
NODE_ENV=development
PORT=3000
HOST=localhost

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/ecommerce_db

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_this_in_production
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# Redis Configuration (Optional - for caching)
REDIS_URL=redis://localhost:6379

# Email Configuration (Nodemailer)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your_email@gmail.com
MAIL_PASS=your_app_password
MAIL_FROM=noreply@ecommerce.com

# File Upload Configuration
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./uploads

# Third-party APIs
# Xendit Payment Gateway
XENDIT_API_KEY=your_xendit_api_key
XENDIT_WEBHOOK_TOKEN=your_xendit_webhook_token

# Grab Shipping API
GRAB_API_KEY=your_grab_api_key
GRAB_API_BASE_URL=https://api.grab.com/grabexpress/v1

# Gojek GoSend API
GOJEK_API_KEY=your_gojek_api_key
GOJEK_API_BASE_URL=https://api.gojek.io

# RajaOngkir API
RAJAONGKIR_API_KEY=your_rajaongkir_api_key
RAJAONGKIR_API_BASE_URL=https://api.rajaongkir.com

# Logging
LOG_LEVEL=debug

# CORS Configuration
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# Frontend URL (for email links, redirects)
FRONTEND_URL=http://localhost:5173

# AWS S3 Configuration (Optional - for image storage)
AWS_S3_BUCKET=ecommerce-bucket
AWS_S3_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
